<%- include('partials/header', { page: 'trades', pageTitle: 'Trades' }) %>

<div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:16px">
  <div>
    <div class="page-title">Paper Trades</div>
    <div class="page-sub">
      <span class="model-badge">v2_elo_hybrid</span>
      <span style="font-size:12px;color:var(--text2)">auto-settlement on</span>
    </div>
  </div>
  <form method="GET" action="/trades" style="display:flex;gap:6px;flex-wrap:wrap">
    <select name="strategy" style="padding:5px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;font-family:var(--sans)">
      <option value="">All strategies</option>
      <% ['T1','T3','T4','T6'].forEach(s => { %><option value="<%= s %>" <%= filters.strategy===s?'selected':'' %>><%= s %></option><% }) %>
    </select>
    <select name="surface" style="padding:5px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;font-family:var(--sans)">
      <option value="">All surfaces</option>
      <% ['Hard','Clay','Grass'].forEach(s => { %><option value="<%= s %>" <%= filters.surface===s?'selected':'' %>><%= s %></option><% }) %>
    </select>
    <select name="period" style="padding:5px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;font-family:var(--sans)">
      <option value="">All time</option>
      <option value="today" <%= filters.period==='today'?'selected':'' %>>Today</option>
      <option value="week" <%= filters.period==='week'?'selected':'' %>>This week</option>
      <option value="month" <%= filters.period==='month'?'selected':'' %>>This month</option>
    </select>
    <button type="submit" class="log-btn">Filter</button>
    <% if(filters.strategy||filters.surface||filters.period) { %>
      <a href="/trades" class="log-btn" style="background:transparent;border-color:var(--border);color:var(--text2)">Clear</a>
    <% } %>
  </form>
</div>

<% if (dailyPnl && dailyPnl.length > 0) { %>
<div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:16px">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
    <div class="section-label" style="margin-bottom:0">Cumulative P&L</div>
    <div style="font-family:var(--mono);font-size:12px;color:<%= parseFloat(stats.total_pnl||0) >= 0 ? 'var(--green)' : 'var(--red)' %>">
      ₹<%= Number(stats.total_pnl||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %> total
    </div>
  </div>
  <canvas id="pnlChart" height="60"></canvas>
</div>
<% } %>

<div class="stat-bar">
  <div class="stat-box">
    <div class="stat-lbl">P&L</div>
    <div class="stat-num <%= parseFloat(stats.total_pnl||0)>=0?'pos':'neg' %>">₹<%= Number(stats.total_pnl||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
    <div class="stat-sub"><%= stats.total || 0 %> settled</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">Win rate</div>
    <div class="stat-num"><%= stats.total > 0 ? Math.round(stats.wins/stats.total*100) : 0 %>%</div>
    <div class="stat-sub"><%= stats.wins||0 %>W · <%= stats.losses||0 %>L</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">ROI</div>
    <div class="stat-num <%= parseFloat(stats.roi||0)>=0?'pos':'neg' %>"><%= stats.roi || '0.0' %>%</div>
    <div class="stat-sub">on risked capital</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">Open</div>
    <div class="stat-num"><%= openTrades ? openTrades.length : 0 %></div>
    <div class="stat-sub">auto-settling</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">Staked</div>
    <div class="stat-num">₹<%= Number(stats.total_risked||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
    <div class="stat-sub"><%= stats.total||0 %> trades</div>
  </div>
</div>

<% if (openTrades && openTrades.length > 0) { %>
<div class="section-label" style="margin-bottom:8px">Open trades · settling automatically</div>
<div class="trade-table-wrap" style="margin-bottom:20px">
  <table class="trade-table">
    <thead><tr>
      <th>Match</th><th>Venue</th><th>Backing</th>
      <th class="r">Odds</th><th class="r">Edge</th><th class="r">Logged IST</th><th class="r">Override</th>
    </tr></thead>
    <tbody>
    <% openTrades.forEach(t => { %>
    <%
      const entryIST = t.entry_time ? (() => {
        const d = new Date(new Date(t.entry_time).getTime() + 5.5*60*60*1000);
        const p = n => n.toString().padStart(2,'0');
        const h = d.getUTCHours(), m2 = d.getUTCMinutes();
        const ampm = h>=12?'PM':'AM';
        return `${h%12||12}:${p(m2)} ${ampm} · ${d.getUTCDate()} ${['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getUTCMonth()]}`;
      })() : '—';
    %>
    <tr>
      <td><div style="font-weight:500"><%= t.player1 %> vs <%= t.player2 %></div></td>
      <td style="color:var(--text2)"><%= t.tournament || '—' %><% if(t.surface) { %> · <%= t.surface %><% } %></td>
      <td style="color:var(--green);font-weight:600"><%= t.entry_player %></td>
      <td style="text-align:right" class="mono"><%= Number(t.entry_odds).toFixed(2) %></td>
      <td style="text-align:right"><span class="edge-pos">+<%= Number(t.confidence||0).toFixed(1) %>%</span></td>
      <td style="text-align:right;font-family:var(--mono);font-size:11px;color:var(--text3)"><%= entryIST %></td>
      <td style="text-align:right">
        <div style="display:flex;gap:4px;justify-content:flex-end">
          <form action="/trades/<%= t.trade_id %>/close" method="POST" style="display:inline">
            <button name="result" value="win" class="settle-won">Won</button>
          </form>
          <form action="/trades/<%= t.trade_id %>/close" method="POST" style="display:inline">
            <button name="result" value="loss" class="settle-lost">Lost</button>
          </form>
        </div>
      </td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<div class="section-label" style="margin-bottom:8px">Settled trades</div>
<div class="trade-table-wrap">
  <table class="trade-table">
    <thead><tr>
      <th>Match</th><th>Venue</th><th>Backed</th>
      <th class="r">Odds</th><th class="r">Stake</th><th class="r">P&L</th><th class="r">Result</th><th class="r">Date</th>
    </tr></thead>
    <tbody>
    <% if (!trades || !trades.length) { %>
      <tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text3)">No trades match filters</td></tr>
    <% } %>
    <% (trades||[]).forEach(t => { %>
    <%
      const won = t.pnl > 0;
      const exitDate = t.exit_time ? (() => {
        const d = new Date(new Date(t.exit_time).getTime() + 5.5*60*60*1000);
        return `${d.getUTCDate()} ${['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getUTCMonth()]}`;
      })() : '—';
    %>
    <tr>
      <td style="font-weight:500"><%= t.player1 %> vs <%= t.player2 %></td>
      <td style="color:var(--text2)"><%= t.tournament || '—' %><% if(t.surface) { %> · <%= t.surface %><% } %></td>
      <td style="color:<%= won ? 'var(--green)' : 'var(--red)' %>;font-weight:600"><%= t.entry_player %></td>
      <td style="text-align:right" class="mono"><%= Number(t.entry_odds).toFixed(2) %></td>
      <td style="text-align:right;color:var(--text2)" class="mono">₹<%= Number(t.entry_stake||500).toLocaleString('en-IN') %></td>
      <td style="text-align:right">
        <span class="<%= won ? 'pnl-pos' : 'pnl-neg' %>">
          <%= won ? '+' : '' %>₹<%= Math.abs(Math.round(t.pnl)).toLocaleString('en-IN') %>
        </span>
      </td>
      <td style="text-align:right"><span class="<%= won ? 'result-won' : 'result-lost' %>"><%= won ? 'Won' : 'Lost' %></span></td>
      <td style="text-align:right;font-size:11px;color:var(--text3)"><%= exitDate %></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<script>
window._pnlData = <%- JSON.stringify(dailyPnl||[]) %>;
drawPnl(window._pnlData);
</script>

<%- include('partials/footer') %>
