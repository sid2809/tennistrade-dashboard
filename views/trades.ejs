<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Paper Trades — TennisTrade</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/header', { page: 'trades' }) %>
<main class="content">
  <div class="page-header"><h1>Paper Trades</h1><div class="header-meta"><%= stats.total %> trades</div></div>
  <form class="filters" method="GET" action="/trades">
    <select name="strategy"><option value="">All Strategies</option>
      <% ['T1','T2','T3','T4','T5','T6'].forEach(s => { %><option value="<%= s %>" <%= filters.strategy===s?'selected':'' %>><%= s %></option><% }) %>
    </select>
    <select name="surface"><option value="">All Surfaces</option>
      <% ['Hard','Clay','Grass'].forEach(s => { %><option value="<%= s %>" <%= filters.surface===s?'selected':'' %>><%= s %></option><% }) %>
    </select>
    <select name="tour"><option value="">All Tours</option>
      <option value="ATP" <%= filters.tour==='ATP'?'selected':'' %>>ATP</option>
      <option value="WTA" <%= filters.tour==='WTA'?'selected':'' %>>WTA</option>
    </select>
    <select name="period"><option value="">All Time</option>
      <option value="today" <%= filters.period==='today'?'selected':'' %>>Today</option>
      <option value="week" <%= filters.period==='week'?'selected':'' %>>This Week</option>
      <option value="month" <%= filters.period==='month'?'selected':'' %>>This Month</option>
    </select>
    <button type="submit" class="btn">Filter</button>
    <% if (filters.strategy||filters.surface||filters.tour||filters.period) { %><a href="/trades" class="btn btn-ghost">Clear</a><% } %>
  </form>
  <div class="stats-grid small">
    <div class="stat-card"><div class="stat-label">P&L</div><div class="stat-value <%= stats.total_pnl>=0?'positive':'negative' %>">₹<%= Number(stats.total_pnl).toLocaleString('en-IN',{maximumFractionDigits:0}) %></div></div>
    <div class="stat-card"><div class="stat-label">ROI</div><div class="stat-value <%= parseFloat(stats.roi)>=0?'positive':'negative' %>"><%= stats.roi %>%</div></div>
    <div class="stat-card"><div class="stat-label">Win Rate</div><div class="stat-value"><%= stats.total>0?(stats.wins/stats.total*100).toFixed(0):0 %>%</div></div>
    <div class="stat-card"><div class="stat-label">Trades</div><div class="stat-value"><%= stats.total %></div></div>
  </div>
  <% if (byStrategy.length>0) { %><div class="strategy-bars"><% byStrategy.forEach(s => { %>
    <div class="strat-row"><span class="badge badge-<%= s.strategy %>"><%= s.strategy %></span><span class="strat-count"><%= s.n %> trades</span><span class="strat-wr"><%= s.n>0?(s.wins/s.n*100).toFixed(0):0 %>%</span><span class="mono <%= s.pnl>=0?'positive':'negative' %>">₹<%= Number(s.pnl).toLocaleString('en-IN',{maximumFractionDigits:0}) %></span></div>
  <% }) %></div><% } %>
  <% if (dailyPnl.length>0) { %><div class="section"><h2>Cumulative P&L</h2><canvas id="pnlChart" height="180"></canvas></div><% } %>
  <div class="section"><div class="table-wrap"><table><thead><tr><th>Strat</th><th>Match</th><th>Surf</th><th>Side</th><th>In</th><th>Out</th><th>P&L</th><th>%</th><th>Exit</th><th>Date</th></tr></thead><tbody>
  <% if (!trades.length) { %><tr><td colspan="10" class="empty-cell">No trades match filters</td></tr><% } %>
  <% trades.forEach(t => { %><tr>
    <td><span class="badge badge-<%= t.strategy %>"><%= t.strategy %></span></td>
    <td><%= t.player1 %> v <%= t.player2 %></td>
    <td><%= t.surface||'—' %></td>
    <td><span class="side-<%= (t.entry_side||'').toLowerCase() %>"><%= t.entry_side %></span></td>
    <td class="mono"><%= Number(t.entry_odds).toFixed(2) %></td>
    <td class="mono"><%= t.exit_odds?Number(t.exit_odds).toFixed(2):'—' %></td>
    <td class="mono <%= (t.pnl||0)>=0?'positive':'negative' %>"><%= t.pnl!==null?(t.pnl>=0?'+':'')+'₹'+Math.abs(t.pnl).toLocaleString('en-IN',{maximumFractionDigits:0}):'—' %></td>
    <td class="mono <%= (t.pnl_pct||0)>=0?'positive':'negative' %>"><%= t.pnl_pct?(t.pnl_pct>=0?'+':'')+Number(t.pnl_pct).toFixed(0)+'%':'—' %></td>
    <td><%= t.exit_type||'—' %></td>
    <td class="dim"><%= t.exit_time?new Date(t.exit_time).toLocaleDateString('en-IN',{day:'2-digit',month:'short'}):'—' %></td>
  </tr><% }) %>
  </tbody></table></div></div>
</main>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const d=<%- JSON.stringify(dailyPnl) %>;if(d.length&&document.getElementById('pnlChart')){let c=0;const cp=d.map(x=>{c+=parseFloat(x.pnl);return c});
new Chart(document.getElementById('pnlChart'),{type:'line',data:{labels:d.map(x=>(x.day||'').split('T')[0]),datasets:[{data:cp,borderColor:cp[cp.length-1]>=0?'#22c55e':'#ef4444',backgroundColor:'transparent',borderWidth:2,tension:.3,pointRadius:2}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#6b7280',maxTicksLimit:10},grid:{color:'#1f2937'}},y:{ticks:{color:'#6b7280',callback:v=>'₹'+v.toLocaleString()},grid:{color:'#1f2937'}}}}});}
</script>
</body></html>
