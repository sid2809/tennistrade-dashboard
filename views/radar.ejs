<%- include('partials/header', { page: 'radar', pageTitle: 'Radar' }) %>

<div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:16px">
  <div>
    <div class="page-title">Live Radar</div>
    <div style="font-size:12px;color:var(--text2);margin-top:4px">
      <% if (typeof openPositions !== 'undefined' && openPositions && openPositions.length > 0) { %>
        <span style="color:var(--green);font-weight:600"><%= openPositions.length %> open positions</span> · polling every 15s
      <% } else { %>
        step9_wire.py · polling live matches · T1/T3/T4/T6 strategies
      <% } %>
    </div>
  </div>
  <div style="display:flex;gap:8px">
    <div style="display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;color:var(--text2)">
      <span style="width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block;animation:pulse 1.5s infinite"></span>
      Scanning
    </div>
  </div>
</div>

<% if (typeof openPositions !== 'undefined' && openPositions && openPositions.length > 0) { %>

<div class="stat-bar" style="grid-template-columns:repeat(4,1fr);margin-bottom:16px">
  <div class="stat-box">
    <div class="stat-lbl">Open positions</div>
    <div class="stat-num"><%= openPositions.length %></div>
    <div class="stat-sub">live trades</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">Today P&L</div>
    <div class="stat-num <%= parseFloat(todayStats&&todayStats.pnl||0)>=0?'pos':'neg' %>">
      ₹<%= Number(todayStats&&todayStats.pnl||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %>
    </div>
    <div class="stat-sub"><%= todayStats&&todayStats.total||0 %> trades · <%= todayStats&&todayStats.wins||0 %> wins</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">Bankroll</div>
    <div class="stat-num">₹<%= Number(bankroll||50000).toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
    <div class="stat-sub">paper trading</div>
  </div>
  <div class="stat-box">
    <div class="stat-lbl">Last activity</div>
    <div style="font-size:12px;margin-top:4px;color:var(--text2)">
      <% if (lastActivity) { %>
        <div style="font-weight:500"><%= lastActivity.strategy %> — <%= lastActivity.player1 %> v <%= lastActivity.player2 %></div>
        <div style="font-size:11px;color:var(--text3);margin-top:2px"><%= lastActivity.entry_time ? new Date(new Date(lastActivity.entry_time).getTime()+5.5*60*60*1000).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '—' %> IST</div>
      <% } else { %>
        <span style="color:var(--text3)">No recent activity</span>
      <% } %>
    </div>
  </div>
</div>

<div class="section-label" style="margin-bottom:8px">Open positions</div>
<div class="trade-table-wrap">
  <table class="trade-table">
    <thead><tr>
      <th>Match</th><th>Venue</th><th>Strategy</th><th>Side</th>
      <th class="r">Entry odds</th><th class="r">Stake</th>
      <th class="r">Score at entry</th><th class="r">Opened IST</th>
    </tr></thead>
    <tbody>
    <% openPositions.forEach(p => { %>
    <%
      const entryIST = p.entry_time ? (() => {
        const d = new Date(new Date(p.entry_time).getTime() + 5.5*60*60*1000);
        const pad = n => n.toString().padStart(2,'0');
        const h = d.getUTCHours(), m2 = d.getUTCMinutes();
        return `${h%12||12}:${pad(m2)} ${h>=12?'PM':'AM'}`;
      })() : '—';
    %>
    <tr>
      <td><div style="font-weight:500"><%= p.player1 %> v <%= p.player2 %></div></td>
      <td style="color:var(--text2)"><%= p.tournament || '—' %><% if(p.surface){%> · <%=p.surface%><% } %></td>
      <td><span class="badge-<%= (p.strategy||'t6').toLowerCase() %>"><%= p.strategy %></span></td>
      <td style="color:var(--text2);font-size:11px"><%= p.entry_side || 'BACK' %></td>
      <td style="text-align:right" class="mono"><%= Number(p.entry_odds).toFixed(2) %></td>
      <td style="text-align:right" class="mono">₹<%= Number(p.entry_stake||500).toLocaleString('en-IN') %></td>
      <td style="text-align:right;font-size:11px;color:var(--text2)"><%= p.entry_score || '—' %></td>
      <td style="text-align:right;font-family:var(--mono);font-size:11px;color:var(--text3)"><%= entryIST %></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<% } else { %>

<div style="text-align:center;padding:48px 24px;border:1px solid var(--border);border-radius:12px;background:var(--bg2);margin-bottom:20px">
  <div style="width:40px;height:40px;border-radius:50%;border:1.5px solid var(--border2);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;opacity:.4">
    <div style="width:8px;height:8px;border-radius:50%;background:var(--text3)"></div>
  </div>
  <div style="font-weight:500;color:var(--text2);margin-bottom:6px">No live matches right now</div>
  <div style="font-size:12px;color:var(--text3);max-width:360px;margin:0 auto">
    Radar activates when ATP/WTA/Challenger matches go live · typically 2 PM – midnight IST
  </div>
</div>

<div class="section-label" style="margin-bottom:8px">How radar works</div>
<div style="border:1px solid var(--border);border-radius:10px;overflow:hidden">
  <div style="display:grid;grid-template-columns:repeat(4,1fr)">
    <% [
      {step:'1', title:'Poll every 15s', desc:'step9_wire.py fetches live matches from API-Tennis'},
      {step:'2', title:'Enrich with Elo', desc:'Player Elo + serve stats loaded from DB'},
      {step:'3', title:'Scan strategies', desc:'T1/T3/T4/T6 signals checked on each match state'},
      {step:'4', title:'Log paper trade', desc:'Signal fires → trade logged automatically'},
    ].forEach((s, i) => { %>
    <div style="padding:16px;border-right:<%= i<3?'1px solid var(--border)':'none' %>">
      <div style="font-family:var(--mono);font-size:10px;color:var(--text3);margin-bottom:6px">Step <%= s.step %></div>
      <div style="font-weight:600;font-size:13px;margin-bottom:4px"><%= s.title %></div>
      <div style="font-size:12px;color:var(--text2);line-height:1.5"><%= s.desc %></div>
    </div>
    <% }) %>
  </div>
</div>

<% if (typeof recentPositions !== 'undefined' && recentPositions && recentPositions.length > 0) { %>
<div class="section-label" style="margin-bottom:8px;margin-top:20px">Recent radar trades</div>
<div class="trade-table-wrap">
  <table class="trade-table">
    <thead><tr>
      <th>Match</th><th>Strategy</th><th class="r">Entry</th><th class="r">Exit</th>
      <th class="r">P&L</th><th class="r">Result</th><th class="r">Date</th>
    </tr></thead>
    <tbody>
    <% recentPositions.forEach(p => { %>
    <tr>
      <td><div style="font-weight:500"><%= p.player1 %> v <%= p.player2 %></div><div style="font-size:11px;color:var(--text3)"><%= p.tournament||'' %></div></td>
      <td><span class="badge-<%= (p.strategy||'t6').toLowerCase() %>"><%= p.strategy %></span></td>
      <td style="text-align:right" class="mono"><%= Number(p.entry_odds).toFixed(2) %></td>
      <td style="text-align:right" class="mono"><%= p.exit_odds ? Number(p.exit_odds).toFixed(2) : '—' %></td>
      <td style="text-align:right"><span class="<%= (p.pnl||0)>=0?'pnl-pos':'pnl-neg' %>"><%= (p.pnl||0)>=0?'+':'' %>₹<%= Math.abs(Math.round(p.pnl||0)).toLocaleString('en-IN') %></span></td>
      <td style="text-align:right"><span class="<%= (p.pnl||0)>0?'result-won':'result-lost' %>"><%= (p.pnl||0)>0?'Won':'Lost' %></span></td>
      <td style="text-align:right;font-size:11px;color:var(--text3)"><%= p.exit_time ? new Date(p.exit_time).toLocaleDateString('en-IN',{day:'2-digit',month:'short'}) : '—' %></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<% } %>

<%- include('partials/footer') %>
