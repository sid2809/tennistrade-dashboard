<%- include('partials/header', { page: 'predictions', pageTitle: 'Predictions' }) %>

<div class="page-header">
  <h1>Predictions & Suggested Trades</h1>
  <div>
    <span class="badge badge-live">LIVE</span>
    <span class="mono muted" style="margin-left:8px"><%= date %></span>
  </div>
</div>

<!-- Stats bar -->
<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-label">Matches today</div>
    <div class="stat-value big"><%= stats.total %></div>
    <div class="stat-sub"><%= stats.atp_wta %> ATP/WTA singles</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">With odds</div>
    <div class="stat-value big"><%= stats.with_odds %></div>
    <div class="stat-sub">pre-match bookmaker odds</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Value bets</div>
    <div class="stat-value big positive"><%= stats.value_bets %></div>
    <div class="stat-sub">15%+ edge over bookmaker</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Tradeable</div>
    <div class="stat-value big"><%= stats.tradeable %></div>
    <div class="stat-sub">T1/T3/T4/T6 potential</div>
  </div>
</div>

<!-- Date picker -->
<div class="filters">
  <% const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0,10); %>
  <% const today = new Date().toISOString().slice(0,10); %>
  <% const tomorrow = new Date(Date.now() + 86400000).toISOString().slice(0,10); %>
  <a href="/predictions?date=<%= yesterday %>" class="filter-btn <%= date === yesterday ? 'active' : '' %>">Yesterday</a>
  <a href="/predictions?date=<%= today %>" class="filter-btn <%= date === today ? 'active' : '' %>">Today</a>
  <a href="/predictions?date=<%= tomorrow %>" class="filter-btn <%= date === tomorrow ? 'active' : '' %>">Tomorrow</a>
</div>

<% if (valueBets && valueBets.length > 0) { %>
<div class="section">
  <div class="section-header">
    <h2>Value Bets (15%+ Edge)</h2>
    <span class="badge badge-live"><%= valueBets.length %> found</span>
  </div>
  <div class="card-grid">
    <% valueBets.forEach(v => { %>
    <div class="prediction-card value-bet">
      <div class="prediction-header">
        <span class="badge badge-t6">T6</span>
        <span class="edge-badge">+<%= v.edge %>% edge</span>
      </div>
      <div class="prediction-match">
        <div class="prediction-player"><%= v.player1 %> <span class="mono muted">(<%= v.p1_elo %>)</span></div>
        <div class="vs">vs</div>
        <div class="prediction-player"><%= v.player2 %> <span class="mono muted">(<%= v.p2_elo %>)</span></div>
      </div>
      <div class="prediction-details">
        <div class="detail-row">
          <span>Tournament</span>
          <span><%= v.tournament %></span>
        </div>
        <div class="detail-row">
          <span>Surface</span>
          <span class="surface-tag surface-<%= (v.surface || '').toLowerCase() %>"><%= v.surface %></span>
        </div>
        <div class="detail-row">
          <span>Bet on</span>
          <span class="highlight"><%= v.bet_on %></span>
        </div>
        <div class="detail-row">
          <span>Model probability</span>
          <span class="mono"><%= v.elo_prob %>%</span>
        </div>
        <div class="detail-row">
          <span>Bookmaker odds</span>
          <span class="mono"><%= v.bet_odds ? parseFloat(v.bet_odds).toFixed(2) : '—' %></span>
        </div>
        <div class="detail-row">
          <span>Suggested stake</span>
          <span class="mono"><%= v.stake_pct %></span>
        </div>
        <div class="detail-row">
          <span>Tour</span>
          <span><%= v.tour %></span>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<% if (tradeable && tradeable.length > 0) { %>
<div class="section">
  <div class="section-header">
    <h2>Tradeable Matches</h2>
    <span class="muted">Matches with T1/T3/T4/T6 potential</span>
  </div>
  <div class="card-grid">
    <% tradeable.forEach(t => { %>
    <div class="prediction-card trade-card">
      <div class="prediction-header">
        <% t.strategies.forEach(s => { %>
          <span class="badge badge-<%= s.type.toLowerCase() %>"><%= s.type %></span>
        <% }) %>
        <span class="mono muted">Elo gap: <%= t.elo_gap %></span>
      </div>
      <div class="prediction-match">
        <div class="prediction-player <%= t.favorite === t.player1 ? 'fav' : '' %>">
          <%= t.player1 %> <span class="mono muted">(<%= t.p1_elo %>)</span>
        </div>
        <div class="vs">vs</div>
        <div class="prediction-player <%= t.favorite === t.player2 ? 'fav' : '' %>">
          <%= t.player2 %> <span class="mono muted">(<%= t.p2_elo %>)</span>
        </div>
      </div>
      <div class="prediction-details">
        <div class="detail-row">
          <span>Tournament</span>
          <span><%= t.tournament %> · <%= t.surface %></span>
        </div>
        <div class="detail-row">
          <span>Favorite</span>
          <span class="highlight"><%= t.favorite %></span>
        </div>
        <% if (t.odds_p1 && t.odds_p2) { %>
        <div class="detail-row">
          <span>Odds</span>
          <span class="mono"><%= parseFloat(t.odds_p1).toFixed(2) %> / <%= parseFloat(t.odds_p2).toFixed(2) %></span>
        </div>
        <% } %>
        <% if (t.p1_stats) { %>
        <div class="detail-row">
          <span><%= t.player1 %></span>
          <span class="mono">Hold <%= t.p1_stats.serve_hold_pct ? (t.p1_stats.serve_hold_pct * 100).toFixed(0) : '—' %>% / Break <%= t.p1_stats.break_rate ? (t.p1_stats.break_rate * 100).toFixed(0) : '—' %>%</span>
        </div>
        <% } %>
        <% if (t.p2_stats) { %>
        <div class="detail-row">
          <span><%= t.player2 %></span>
          <span class="mono">Hold <%= t.p2_stats.serve_hold_pct ? (t.p2_stats.serve_hold_pct * 100).toFixed(0) : '—' %>% / Break <%= t.p2_stats.break_rate ? (t.p2_stats.break_rate * 100).toFixed(0) : '—' %>%</span>
        </div>
        <% } %>
        <% t.strategies.forEach(s => { %>
        <div class="strategy-note">
          <span class="badge badge-<%= s.type.toLowerCase() %> small"><%= s.type %></span>
          <span><%= s.desc %></span>
          <span class="badge badge-conf-<%= s.confidence.toLowerCase().replace(/[- ]/g,'') %>"><%= s.confidence %></span>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<% if (schedule && schedule.length > 0) { %>
<div class="section">
  <div class="section-header">
    <h2>Full Schedule (<%= date %>)</h2>
    <span class="mono muted"><%= stats.total %> singles matches</span>
  </div>
  <% schedule.forEach(group => { %>
  <div class="schedule-group">
    <div class="schedule-header">
      <span class="badge badge-<%= group.tour === 'ATP' ? 'back' : group.tour === 'WTA' ? 'lay' : 'closed' %>"><%= group.tour %></span>
      <span class="schedule-tournament"><%= group.tournament %></span>
      <span class="surface-tag surface-<%= (group.surface || '').toLowerCase() %>"><%= group.surface %></span>
    </div>
    <div class="table-wrap">
      <table class="table compact">
        <thead>
          <tr>
            <th>Time</th>
            <th>Round</th>
            <th>Player 1</th>
            <th>Elo</th>
            <th>Player 2</th>
            <th>Elo</th>
            <th>Model</th>
            <th>Odds</th>
            <th>Edge</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% group.matches.forEach(m => { %>
          <tr>
            <td class="mono small"><%= m.time_ist || m.time || '—' %></td>
            <td><%= m.round || '—' %></td>
            <td class="player-name"><%= m.player1 %></td>
            <td class="mono"><%= m.p1_elo %></td>
            <td class="player-name"><%= m.player2 %></td>
            <td class="mono"><%= m.p2_elo %></td>
            <td class="mono"><%= m.elo_prob_p1 %>%</td>
            <td class="mono">
              <% if (m.odds_p1) { %>
                <%= parseFloat(m.odds_p1).toFixed(2) %> / <%= parseFloat(m.odds_p2).toFixed(2) %>
              <% } else { %>
                —
              <% } %>
            </td>
            <td class="mono">
              <% const bestEdge = Math.max(parseFloat(m.edge_p1)||0, parseFloat(m.edge_p2)||0); %>
              <% if (bestEdge > 15) { %>
                <span class="positive">+<%= bestEdge.toFixed(0) %>%</span>
              <% } else if (bestEdge > 5) { %>
                +<%= bestEdge.toFixed(0) %>%
              <% } else if (m.has_odds) { %>
                <%= bestEdge.toFixed(0) %>%
              <% } else { %>
                —
              <% } %>
            </td>
            <td><%= m.status %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% }) %>
</div>
<% } else if (!predictions || predictions.length === 0) { %>
<div class="empty-state">
  <p>No matches found for <%= date %>.</p>
  <p class="muted">Try checking tomorrow's schedule or verify the API-Tennis key is configured.</p>
</div>
<% } %>

<%- include('partials/footer') %>
